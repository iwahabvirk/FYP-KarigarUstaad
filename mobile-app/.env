# API Configuration
# Use one of the following based on your setup:
# - For local development (web): http://localhost:5000/api
# - For physical device/emulator: http://<YOUR_LOCAL_IP>:5000/api
#   (Replace <YOUR_LOCAL_IP> with your backend machine's local network IP, e.g., 192.168.x.x)
# 
# To find your local IP on Windows:
#   1. Open Command Prompt
#   2. Type: ipconfig
#   3. Look for "IPv4 Address" under your network adapter (usually 192.168.x.x or 10.x.x.x)
# 
# Example: http://192.168.1.100:5000/api
EXPO_PUBLIC_API_URL=http://192.168.100.196:5000/api

# Environment
NODE_ENV=development
